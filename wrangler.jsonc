{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "global-market-sentiment",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-22",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "triggers": {
    "crons": ["*/5 * * * *"]
  }
}
